{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node copy404.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:integration:watch": "vitest tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest run --reporter verbose",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality:unused": "knip",
    "quality:deps": "depcheck",
    "quality:lint": "eslint .",
    "quality:coverage": "vitest run --coverage",
    "quality": "npm run quality:unused && npm run quality:deps && npm run quality:lint && npm run quality:coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/jest-dom": "^6.9.1",
    "axios": "^1.15.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@mswjs/interceptors": "^0.41.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.18.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.5"
  }
}
